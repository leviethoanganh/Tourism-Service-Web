extends ../layouts/default.pug


block main
  h1.box-title Create Admin Account

  .section-8
    form(id="setting-account-admin-create-form")
      .inner-group
        label.inner-label(for="fullName") Full Name *
        input(type="text" id="fullName" name="fullName")
      .inner-group
        label.inner-label(for="email") Email *
        input(type="email" id="email" name="email")
      .inner-group
        label.inner-label(for="phone") Phone Number
        input(type="text" id="phone" name="phone")
      .inner-group
        label.inner-label(for="role") Role Group
        select(id="role" name="role")
          each item in roleList
            option(value=item.id) #{item.name}
      .inner-group
        label.inner-label(for="positionCompany") Position *
        input(type="text" id="positionCompany" name="positionCompany")
      .inner-group
        label.inner-label(for="status") Status
        select(id="status" name="status")
          option(value="initial") Pending
          option(value="active") Active
          option(value="inactive") Inactive
      .inner-group
        label.inner-label(for="password") Password *
        input(type="text" id="password" name="password")
      .inner-group.inner-two-col
        label.inner-label(for="avatar") Avatar
        div(class="inner-upload-image")
          input(type="file" id="avatar" name="avatar" filepond-image)
      .inner-button.inner-two-col
        button Create
    .inner-back
      a(href=`/${pathAdmin}/setting/account-admin/list`) Back to list
