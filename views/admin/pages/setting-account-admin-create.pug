extends ../layouts/default.pug


block main
  h1.box-title Tạo tài khoản quản trị

  .section-8
    form(id="setting-account-admin-create-form")
      .inner-group
        label.inner-label(for="fullName") Họ tên *
        input(type="text" id="fullName" name="fullName")
      .inner-group
        label.inner-label(for="email") Email *
        input(type="email" id="email" name="email")
      .inner-group
        label.inner-label(for="phone") Số điện thoại
        input(type="text" id="phone" name="phone")
      .inner-group
        label.inner-label(for="role") Nhóm quyền
        select(id="role" name="role")
          each item in roleList
            option(value=item.id) #{item.name}
      .inner-group
        label.inner-label(for="positionCompany") Chức vụ *
        input(type="text" id="positionCompany" name="positionCompany")
      .inner-group
        label.inner-label(for="status") Trạng thái
        select(id="status" name="status")
          option(value="initial") Khởi tạo
          option(value="active") Hoạt động
          option(value="inactive") Tạm dừng
      .inner-group
        label.inner-label(for="password") Mật khẩu *
        input(type="text" id="password" name="password")
      .inner-group.inner-two-col
        label.inner-label(for="avatar") Ảnh đại diện
        div(class="inner-upload-image")
          input(type="file" id="avatar" name="avatar" filepond-image)
      .inner-button.inner-two-col
        button Tạo mới
    .inner-back
      a(href=`/${pathAdmin}/setting/account-admin/list`) Quay lại danh sách
