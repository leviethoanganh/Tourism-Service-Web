// Header
header.header
  .container
    .inner-wrap
      button.inner-button-menu
        img(
          alt="" 
          src="/client/assets/images/icon-menu.png"
          )
      a.inner-logo(href="/")
        img(
          alt=settingWebsiteInfo.websiteName
          src="/client/assets/images/logo.png"
          )
      nav.inner-menu
        ul
          li
            a.active(href="/") Trang Chủ
          each item in categoryList
              a(href=`/category/${item.slug}`) #{item.name}
              if (item.children && item.children.length > 0)
                i.fa-solid.fa-caret-down
                ul.inner-sub
                  each itemChild in item.children
                    li
                      a(href=`/category/${itemChild.slug}`) #{itemChild.name}                  
          li
            a(href="#") Tin Tức
          li
            a(href="#") Liên Hệ
        .inner-overlay
      a.inner-cart(href="/cart")
        img(
          alt="" 
          src="/client/assets/images/icon-cart.png"
          )
        span
          img(
            alt="" 
            src="/client/assets/images/icon-arrow-left.png"
            )
          div(mini-cart) 0
// End Header