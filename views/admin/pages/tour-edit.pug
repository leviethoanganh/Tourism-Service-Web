extends ../layouts/default.pug
include ../mixins/checkbox.pug
include ../mixins/options.pug

block main
    h1.box-title Edit Tour

    .section-8
        form(id="tour-edit-form")
            //- ID ẩn để gửi lên backend xử lý cập nhật
            .inner-group(style="display: none;")
                label.inner-label(for="id") Id *
                input(type="text" id="id" name="id" value=tourDetail.id)

            .inner-group
                label.inner-label(for="name") Tour Name *
                input(type="text" id="name" name="name" value=tourDetail.name)

            .inner-group
                label.inner-label(for="category") Category
                select(id="category" name="category")
                    option(value="") -- Select category --
                    +options(categoryList, 0, tourDetail.category)

            .inner-group
                label.inner-label(for="position") Position
                input(type="number" id="position" name="position" value=tourDetail.position)

            .inner-group
                label.inner-label(for="status") Status
                select(id="status" name="status")
                    option(
                        value="active"
                        selected=(tourDetail.status == "active")
                    ) Active
                    option(
                        value="inactive"
                        selected=(tourDetail.status == "inactive")
                    ) Inactive

            .inner-group.inner-two-col
                label.inner-label(for="avatar") Avatar
                div(class="inner-upload-image")
                    input(
                        type="file"
                        id="avatar"
                        name="avatar"
                        filepond-image
                        image-default=tourDetail.avatar
                    )
            .inner-group.inner-two-col
                label.inner-label(for="images") Image List
                div(class="inner-upload-image-multi")
                    input(
                        type="file"
                        multiple
                        id="images"
                        name="images"
                        filepond-image-multi
                        data-allow-reorder="true"
                        list-image-default=tourDetail.images
                    )

            .inner-group
                label.inner-label Original Price
                .inner-input-list
                    .inner-input-item
                        label(for="priceAdult") Adult
                        input(type="number" id="priceAdult" name="priceAdult" value=tourDetail.priceAdult)
                    .inner-input-item
                        label(for="priceChildren") Children
                        input(type="number" id="priceChildren" name="priceChildren" value=tourDetail.priceChildren)
                    .inner-input-item
                        label(for="priceBaby") Baby
                        input(type="number" id="priceBaby" name="priceBaby" value=tourDetail.priceBaby)

            .inner-group
                label.inner-label Sale Price
                .inner-input-list
                    .inner-input-item
                        label(for="priceNewAdult") Adult
                        input(type="number" id="priceNewAdult" name="priceNewAdult" value=tourDetail.priceNewAdult)
                    .inner-input-item
                        label(for="priceNewChildren") Children
                        input(type="number" id="priceNewChildren" name="priceNewChildren" value=tourDetail.priceNewChildren)
                    .inner-input-item
                        label(for="priceNewBaby") Baby
                        input(type="number" id="priceNewBaby" name="priceNewBaby" value=tourDetail.priceNewBaby)

            .inner-group
                label.inner-label Remaining Stock
                .inner-input-list
                    .inner-input-item
                        label(for="stockAdult") Adult
                        input(type="number" id="stockAdult" name="stockAdult" value=tourDetail.stockAdult)
                    .inner-input-item
                        label(for="stockChildren") Children
                        input(type="number" id="stockChildren" name="stockChildren" value=tourDetail.stockChildren)
                    .inner-input-item
                        label(for="stockBaby") Baby
                        input(type="number" id="stockBaby" name="stockBaby" value=tourDetail.stockBaby)

            .inner-group
                label.inner-label Tour Departure Locations
                .inner-checkbox-list
                    each item in cityList
                        .inner-checkbox-item
                            +checkbox-30(
                                "locations",
                                `locations-${item.id}`,
                                item.id,
                                tourDetail.locations.includes(item.id)
                            )
                            label(for=`locations-${item.id}`) #{item.name}

            .inner-group
                label.inner-label(for="time") Duration
                input(type="text" id="time" name="time" value=tourDetail.time)

            .inner-group
                label.inner-label(for="vehicle") Transport
                input(type="text" id="vehicle" name="vehicle" value=tourDetail.vehicle)

            .inner-group
                label.inner-label(for="departureDate") Departure Date
                input(type="date" id="departureDate" name="departureDate" value=tourDetail.departureDateFormat)

            .inner-group.inner-two-col
                label.inner-label(for="information") Tour Information
                textarea(id="information" name="information" textarea-mce) #{tourDetail.information}

            .inner-group.inner-two-col
                label.inner-label Tour Schedule
                .inner-schedule
                    .inner-schedule-list
                        if (tourDetail.schedules && tourDetail.schedules.length > 0)
                            each item in tourDetail.schedules
                                .inner-schedule-item
                                    .inner-schedule-head
                                        .inner-schedule-button.inner-move
                                            i.fa-solid.fa-up-down-left-right
                                        input(type="text" value=item.title placeholder="Day title...")
                                        .inner-schedule-button.inner-remove
                                            i.fa-solid.fa-trash-can
                                        .inner-schedule-button.inner-more
                                            i.fa-solid.fa-angle-down
                                    .inner-schedule-body
                                        textarea(textarea-mce) #{item.description}
                        else
                            .inner-schedule-item
                                .inner-schedule-head
                                    .inner-schedule-button.inner-move
                                        i.fa-solid.fa-up-down-left-right
                                    input(type="text" placeholder="Day title...")
                                    .inner-schedule-button.inner-remove
                                        i.fa-solid.fa-trash-can
                                    .inner-schedule-button.inner-more
                                        i.fa-solid.fa-angle-down
                                .inner-schedule-body
                                    textarea(textarea-mce)
                    .inner-schedule-create + Add Schedule

            .inner-button.inner-two-col
                button(type="submit") Update

        .inner-back
            a(href=`/${pathAdmin}/tour/list`) Back to list
