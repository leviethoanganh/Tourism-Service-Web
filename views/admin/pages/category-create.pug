extends ../layouts/default.pug
include ../mixins/options.pug

block main 
  if (pers.includes("category-create"))
    h1.box-title Tạo danh mục

    .section-8
      form(id="category-create-form")
        .inner-group
          label.inner-label(for="name") Tên danh mục *
          input(type="text" id="name" name="name")
        .inner-group
          label.inner-label(for="parent") Danh mục cha
          select(id="parent" name="parent")
            option(value="") -- Chọn danh mục --
            +options(categoryList)
        .inner-group
          label.inner-label(for="position") See you
          input(type="number" id="position" name="position")
        .inner-group
          label.inner-label(for="status") Trạng thái
          select(id="status" name="status")
            option(value="active") Hoạt động
            option(value="inactive") Tạm dừng
        .inner-group.inner-two-col
          label.inner-label(for="avatar") Ảnh đại diện
          div(class="inner-upload-image")
            input(type="file" id="avatar" name="avatar" filepond-image)
        .inner-group.inner-two-col
          label.inner-label(for="description") Mô tả
          textarea(id="description" name="description" textarea-mce)
        .inner-button.inner-two-col
          button Tạo mới
      .inner-back
        a(href=`/${pathAdmin}/category/list`) Quay lại danh sách
