extends ../layouts/default.pug
include ../mixins/checkbox.pug


block main
  h1.box-title Role Groups

  //- Section 5
  .section-5
    .inner-wrap
      .inner-change-status
        .inner-item
          select
            option(value="") -- Action --
            option(value="") Active
            option(value="") Inactive
            option(value="") Delete
        .inner-item
          button Apply
      .inner-search
        <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Search")
      .inner-button-create
        a(href=`/${pathAdmin}/setting/role/create`) + Create New
  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th.text-left
              +checkbox-30("", "")
            th.text-left Role Name
            th.text-left Description
            th.text-left Created By
            th.text-left Updated By
            th.text-left Actions
        tbody
          each item in roleList
            tr
              td.text-left
                +checkbox-30("", "")
              td.text-left #{item.name}
              td.text-left #{item.description}
              td.text-left
                if (item.createdByFullName)
                  div #{item.createdByFullName}
                  div.inner-small #{item.createdAtFormat}
              td.text-left
                if (item.updatedByFullName)
                  div #{item.updatedByFullName}
                  div.inner-small #{item.updatedAtFormat}

              td.text-left
                .box-actions
                  a(href=`/${pathAdmin}/setting/role/edit/${item.id}`
                      class="inner-edit")
                    <i class="fa-solid fa-pen-to-square"></i>
                  button(
                    class="inner-remove"
                    button-delete
                    data-api=`/${pathAdmin}/setting/role/delete/${item.id}`
                    )
                    <i class="fa-solid fa-trash-can"></i>
  //- End Section 6

  //- Section 7
  .section-7
    span(class="inner-label") Showing 1 - 9 of 78
    select(class="inner-pagination")
      option Page 1
      option Page 2
      option Page 3
  //- End Section 7
